[Unit]
Description=mr.cleaner Telegram moderation bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/mr-cleaner
EnvironmentFile=/opt/mr-cleaner/.env
ExecStart=/opt/mr-cleaner/.venv/bin/python /opt/mr-cleaner/bot.py
Restart=always
RestartSec=5
User=mr-cleaner
Group=mr-cleaner

[Install]
WantedBy=multi-user.target
