# Telegram bot token from @BotFather
BOT_TOKEN=your_telegram_bot_token

# OpenAI-compatible endpoint settings
OPENAI_API_KEY=your_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
MODERATION_MODE=strict
# Optional: channel/chat ID for delete audit logs (example: -1001234567890)
AUDIT_CHAT_ID=

# Moderation behavior
# 1 = log each moderation decision to stdout, 0 = quiet
DEBUG=1

# Optional: private-chat admin password for bot controls
ADMIN_PASSWORD=change_me
# Optional but strongly recommended for webhook deployments
WEBHOOK_SECRET=change_me_long_random_string
# Persist successful logins for this many seconds (default: 30 days)
ADMIN_SESSION_TTL_SECONDS=2592000

# Optional: persistent feature toggle state file
# Local default is bot_state.json. Modal mounts /state and overrides this to /state/bot_state.json.
STATE_FILE=bot_state.json

# Production runtime knobs
# 1 = skip old queued Telegram updates on restart, 0 = replay backlog
DROP_PENDING_UPDATES=1
# Cache admin status lookups for this many seconds
ADMIN_CACHE_TTL_SECONDS=300
# OpenAI-compatible request timeout in seconds
OPENAI_TIMEOUT_SECONDS=20
# Limit concurrent AI moderation requests
MAX_MODERATION_CONCURRENCY=8
